{
  "name": "washtrack-pro",
  "version": "3.0.0",
  "private": true,
  "description": "WashTrack Pro — car wash and automotive maintenance business management app.",
  "scripts": {
    "build:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --minify",
    "watch:css": "tailwindcss -i ./css/input.css -o ./css/styles.css --watch",
    "start": "http-server . -p 4173 -c-1 -s",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.19"
  }
}
